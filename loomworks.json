{
  "name": "reactive",
  "projects": {
    "reactive": {
      "meson": {
        "configurations": {
          "Debug": {
            "variant": "Debug",
            "options": {
              "wrap_mode": "forcefallback"
            }
          },
          "Sanitize": {
            "variant": "RelWithDebInfo",
            "options": {
              "wrap_mode": "forcefallback",
              "b_lundef": "false",
              "b_sanitize": "address,undefined"
            }
          },
          "Release": {
            "variant": "Release",
            "options": {
              "wrap_mode": "forcefallback"
            }
          },
          "Tracy": {
            "variant": "Release",
            "options": {
              "wrap_mode": "forcefallback",
              "tracy_enable": "true"
            }
          }
        }
      },
      "launch": {
        "app": {
          "working_dir": ".",
          "target": "testapp1"
        }
      },
      "path": "."
    }
  },
  "configuration_sets": {
    "Sanitize": {
      "reactive": "Sanitize"
    },
    "Debug": {
      "reactive": "Debug"
    },
    "Release": {
      "reactive": "Release"
    },
    "Tracy": {
      "reactive": "Tracy"
    }
  }
}
